{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignore": [
		".bun/**",
		"dist/**",
		"coverage/**",
		"test-results/**",
		".seeds/**"
	],
	"ignoreUnresolved": ["bun-types"],
	"workspaces": {
		".": {
			"entry": [
				"src/index.ts",
				"extensions/**/*.ts",
				"scripts/**/*.ts",
				"**/*.test.ts"
			],
			"project": ["src/**/*.ts", "extensions/**/*.ts", "scripts/**/*.ts"]
		}
	}
}
